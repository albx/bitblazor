    [Fact]
    public void BitToolbar_Should_Render_Default_Markup_Correctly()
    {
        var component = Render(
            @<BitToolbar>
                <BitToolbarItem Active="true" Label="messages" IconName="@Icons.ItComment" />
                <BitToolbarItem Label="images" IconName="@Icons.ItCamera" />
                <BitToolbarItem Label="documents" IconName="@Icons.ItFile" />
                <BitToolbarItem Label="privacy" IconName="@Icons.ItLocked" />
                <BitToolbarItem Label="favourites" IconName="@Icons.ItStarOutline" />
            </BitToolbar>);

        component.MarkupMatches(
            @<nav class="toolbar">
                <ul>
                    <li>
                        <a class="active">
                            <svg class="icon"><use href="/_content/BitBlazor/bootstrap-italia/svg/sprites.svg#it-comment"></use></svg>
                            <span class="toolbar-label">messages</span>
                        </a>
                    </li>
                    <li>
                        <a class="">
                            <svg class="icon"><use href="/_content/BitBlazor/bootstrap-italia/svg/sprites.svg#it-camera"></use></svg>
                            <span class="toolbar-label">images</span>
                        </a>
                    </li>
                    <li>
                        <a class="">
                            <svg class="icon"><use href="/_content/BitBlazor/bootstrap-italia/svg/sprites.svg#it-file"></use></svg>
                            <span class="toolbar-label">documents</span>
                        </a>
                    </li>
                    <li>
                        <a class="">
                            <svg class="icon"><use href="/_content/BitBlazor/bootstrap-italia/svg/sprites.svg#it-locked"></use></svg>
                            <span class="toolbar-label">privacy</span>
                        </a>
                    </li>
                    <li>
                        <a class="">
                            <svg class="icon"><use href="/_content/BitBlazor/bootstrap-italia/svg/sprites.svg#it-star-outline"></use></svg>
                            <span class="toolbar-label">favourites</span>
                        </a>
