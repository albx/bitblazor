    [Fact]
    public void BitToolbar_Should_Not_Render_Href_Attribute_When_Href_Is_Not_Set()
    {
        var component = Render(
            @<BitToolbar>
                <BitToolbarItem Label="Search" IconName="@Icons.ItSearch" />
            </BitToolbar>);

        Assert.Null(component.Find("a").GetAttribute("href"));
    }

    [Fact]
    public void BitToolbar_Should_Render_Href_Attribute_When_Href_Is_Provided()
    {
        var component = Render(
            @<BitToolbar>
                <BitToolbarItem Label="Search" IconName="@Icons.ItSearch" Href="/search" />
            </BitToolbar>);

        Assert.Equal("/search", component.Find("a").GetAttribute("href"));
    }

    [Fact]
    public void BitToolbar_Should_Apply_Custom_CssClass()
    {
        var component = Render(
            @<BitToolbar CssClass="my-custom-toolbar">
                <BitToolbarItem Label="Search" IconName="@Icons.ItSearch" />
            </BitToolbar>);

        Assert.True(component.Find("nav").ClassList.Contains("my-custom-toolbar"));
    }
