                    <li class="page-item">
                        <a class="page-link" href="/items/1">
                            <svg class="icon icon-primary"><use href="/_content/BitBlazor/bootstrap-italia/svg/sprites.svg#it-chevron-left" /></svg>
                            <span class="visually-hidden">previous page</span>
